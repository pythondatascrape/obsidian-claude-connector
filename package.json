{
  "name": "obsidian-connector",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "test": "jest"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.21.0",
    "jest": "^29.0.0",
    "obsidian": "latest",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "obsidian": "<rootDir>/tests/__mocks__/obsidian.ts"
    },
    "testMatch": ["**/tests/**/*.test.ts"]
  }
}
